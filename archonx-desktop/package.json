{
  "name": "archonx-desktop",
  "version": "0.1.0",
  "description": "ArchonX OS Desktop Application - Control, Monitor, Deploy AI Agents",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run tauri dev\" \"npm run backend:dev\"",
    "build": "npm run frontend:build && npm run tauri build",
    "backend:dev": "cd backend && python -m uvicorn app:app --reload --host 127.0.0.1 --port 8000",
    "backend:install": "cd backend && pip install -r requirements.txt",
    "frontend:build": "vite build",
    "tauri": "tauri",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.4.7",
    "framer-motion": "^10.16.4",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.0.5",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tauri-apps/api": "^1.5.3",
    "@tanstack/react-query": "^5.28.0",
    "@tanstack/react-table": "^8.11.2",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.7",
    "vite-plugin-svgr": "^4.2.0"
  }
}
