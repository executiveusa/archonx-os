{
  "meta": {
    "spec_id": "SYNTHIA_3_0_SPEC",
    "version": "1.0.0",
    "phase": "PHASE_1",
    "created_at": "2026-03-27T00:00:00Z",
    "author": "ARCHITECT — BMAD A2A",
    "status": "AWAITING_BUILDER_REVIEW",
    "references": [
      ".agent-souls/white/synthia_queen.soul.md",
      "GAP_006 from PHASE_0_GAP_ANALYSIS",
      "archonx-config.json (product definitions)",
      "AGENTS.md (mandatory-design-law + UDEC requirements)"
    ]
  },

  "overview": {
    "name": "SYNTHIA 3.0 — Spanish-First LATAM Design AI",
    "description": "A standalone Next.js web application. AI-powered design tool targeting LATAM female entrepreneurs. Non-technical users (Ivette runs it). Spanish-first UI with MXN pricing. Subscription model.",
    "location": "synthia-3-0/ (new app at repo root)",
    "deployed_at": "Vercel (synthia.archonx.io or synthia-3-0.vercel.app)",
    "target_market": "LATAM female entrepreneurs — Mexico, Colombia, Argentina, Peru primary",
    "quality_gate": "UDEC 14-axis 8.5/10 MINIMUM — no exceptions"
  },

  "technology_stack": {
    "framework": "Next.js 15 (App Router)",
    "language": "TypeScript",
    "styling": "Tailwind CSS 3 + shadcn/ui components",
    "auth": "Supabase Auth (email/password + Google OAuth)",
    "database": "Supabase PostgreSQL",
    "payments": "Stripe (MXN currency, recurring subscriptions)",
    "ai_backend": "ARCHON-X API (calls kernel.execute_task for AI features)",
    "i18n": "next-intl (Spanish default, English available)",
    "package_manager": "pnpm",
    "deployment": "Vercel"
  },

  "file_structure": {
    "synthia-3-0/": {
      "package.json": "deps: next@15, react@18, tailwindcss, supabase-js, stripe, next-intl, shadcn/ui",
      "tsconfig.json": "strict TypeScript",
      "next.config.ts": "i18n routing, image optimization, Vercel config",
      "middleware.ts": "Auth guard + locale detection",
      "src/": {
        "app/": {
          "[locale]/": {
            "page.tsx": "Landing page (Spanish default)",
            "layout.tsx": "Root layout with nav + locale provider",
            "dashboard/": {
              "page.tsx": "User dashboard — projects overview",
              "layout.tsx": "Dashboard shell with sidebar"
            },
            "design/": {
              "[projectId]/page.tsx": "Design workspace — AI-assisted",
              "new/page.tsx": "Create new design project"
            },
            "pricing/page.tsx": "Pricing page (MXN, Free/Pro/Premium)",
            "auth/": {
              "login/page.tsx": "Login page",
              "signup/page.tsx": "Signup page",
              "callback/page.tsx": "OAuth callback"
            }
          },
          "api/": {
            "ai/generate/route.ts": "POST — AI design generation (calls ARCHON-X kernel)",
            "ai/refine/route.ts": "POST — AI design refinement",
            "stripe/checkout/route.ts": "POST — Stripe checkout session creation",
            "stripe/webhook/route.ts": "POST — Stripe webhook handler",
            "projects/route.ts": "GET/POST — project CRUD",
            "projects/[id]/route.ts": "GET/PUT/DELETE — single project"
          }
        },
        "components/": {
          "ui/": "shadcn/ui components (button, card, dialog, input, etc.)",
          "landing/": {
            "Hero.tsx": "Hero section — Spanish headline, CTA",
            "Features.tsx": "Feature cards — design capabilities",
            "Pricing.tsx": "Pricing cards — Free/Pro/Premium MXN",
            "Testimonials.tsx": "Social proof — LATAM entrepreneurs",
            "Footer.tsx": "Footer with links and LATAM contact"
          },
          "dashboard/": {
            "ProjectCard.tsx": "Project preview card",
            "ProjectGrid.tsx": "Projects grid layout",
            "CreateProjectButton.tsx": "+ New Project CTA",
            "UsageIndicator.tsx": "Plan usage (designs this month)"
          },
          "design/": {
            "DesignCanvas.tsx": "Main design workspace",
            "AIAssistPanel.tsx": "AI prompt input + suggestions panel",
            "StyleGuide.tsx": "Brand colors, fonts, assets panel",
            "ExportButton.tsx": "Export design as PNG/PDF/SVG"
          },
          "shared/": {
            "Navbar.tsx": "Top navigation with logo + user menu",
            "Sidebar.tsx": "Dashboard sidebar nav",
            "LanguageSwitcher.tsx": "ES/EN toggle",
            "SubscriptionBadge.tsx": "User's current plan badge"
          }
        },
        "lib/": {
          "supabase/": {
            "client.ts": "Supabase browser client",
            "server.ts": "Supabase server client (SSR)"
          },
          "stripe/": {
            "client.ts": "Stripe client (uses Infisical key)",
            "plans.ts": "Plan definitions + MXN pricing"
          },
          "archonx/": {
            "client.ts": "ARCHON-X API client (calls kernel REST API)"
          },
          "i18n/": {
            "messages/es.json": "Spanish translations",
            "messages/en.json": "English translations"
          }
        },
        "types/": {
          "project.ts": "Project, DesignAsset, ProjectStatus types",
          "user.ts": "User, Subscription, PlanTier types",
          "ai.ts": "AIRequest, AIResponse, GenerationMode types"
        }
      },
      "supabase/": {
        "migrations/": {
          "001_init.sql": "users, projects, subscriptions, usage tables"
        }
      }
    }
  },

