  "database_schema": {
    "users": {
      "id": "uuid PK (Supabase Auth user_id)",
      "email": "text NOT NULL",
      "full_name": "text",
      "preferred_language": "text DEFAULT 'es'",
      "plan_tier": "text DEFAULT 'free'",
      "stripe_customer_id": "text",
      "created_at": "timestamptz"
    },
    "projects": {
      "id": "uuid PK",
      "user_id": "uuid FK → users.id",
      "name": "text NOT NULL",
      "description": "text",
      "status": "text (draft|active|archived)",
      "design_data": "jsonb (design state)",
      "thumbnail_url": "text",
      "created_at": "timestamptz",
      "updated_at": "timestamptz"
    },
    "subscriptions": {
      "id": "uuid PK",
      "user_id": "uuid FK → users.id",
      "stripe_subscription_id": "text",
      "plan_tier": "text",
      "status": "text (active|past_due|canceled)",
      "current_period_end": "timestamptz",
      "created_at": "timestamptz"
    },
    "ai_usage": {
      "id": "uuid PK",
      "user_id": "uuid FK → users.id",
      "month_year": "text (YYYY-MM)",
      "generations_used": "int DEFAULT 0",
      "updated_at": "timestamptz"
    }
  },

  "ai_integration": {
    "endpoint": "ARCHON-X kernel REST API",
    "env_var": "ARCHONX_API_URL (from Infisical: SYNTHIA_ARCHONX_API_URL)",
    "auth": "Bearer token from Infisical: SYNTHIA_ARCHONX_API_KEY",
    "design_generation_flow": {
      "1": "User inputs prompt in Spanish",
      "2": "Frontend POST /api/ai/generate with {prompt, style_preferences, brand_colors}",
      "3": "API route calls ARCHON-X kernel: task requires synthia_queen agent",
      "4": "Kernel routes to synthia_queen soul with prompt context",
      "5": "AI generates design spec (JSON: colors, layout, typography, imagery direction)",
      "6": "Frontend renders design spec in DesignCanvas",
      "7": "User can refine via /api/ai/refine"
    }
  },

  "i18n": {
    "default_locale": "es",
    "supported_locales": ["es", "en"],
    "routing": "/es/dashboard, /en/dashboard (locale prefix)",
    "auto_detect": "browser Accept-Language header → redirect to correct locale",
    "key_spanish_strings": {
      "nav_dashboard": "Mi Espacio",
      "nav_pricing": "Precios",
      "hero_headline": "Diseña tu marca como una profesional",
      "hero_sub": "SYNTHIA es tu asistente de diseño con inteligencia artificial. Sin experiencia previa necesaria.",
      "cta_primary": "Empieza gratis",
      "cta_secondary": "Ver cómo funciona",
      "plan_free_cta": "Empieza gratis",
      "plan_pro_cta": "Empieza con Pro",
      "plan_premium_cta": "Contactar ventas"
    }
  },

  "udec_design_requirements": {
    "target_score": "8.5/10 minimum",
    "color_palette": {
      "primary": "#7C3AED (vibrant purple — feminine, professional, tech)",
      "primary_dark": "#5B21B6",
      "accent": "#F59E0B (gold — premium feel)",
      "background": "#0F0F23 (near-black — sophisticated)",
      "surface": "#1A1A3E (dark surface)",
      "text_primary": "#F0F0FF",
      "text_secondary": "#9CA3AF",
      "success": "#10B981",
      "error": "#EF4444"
    },
    "typography": {
      "heading": "Plus Jakarta Sans (Google Fonts — modern, clean, LATAM appeal)",
      "body": "Inter",
      "accent": "Space Grotesk (for badges, labels, technical)"
    },
    "non_negotiables": [
      "Spanish FIRST — English is not the default",
      "MXN pricing ALWAYS displayed first, USD in small text parentheses",
      "No generic SaaS templates (Vercel/Linear-inspired but distinct)",
      "Mobile responsive — LATAM users are mobile-first",
      "Accessibility: WCAG AA contrast ratios, proper aria labels",
      "Load performance: < 2s LCP on 4G mobile connection",
      "Error states: never blank/silent — always helpful message in Spanish",
      "Progress indicators: AI generation must show progress (not just spinner)",
      "Onboarding: 3-step setup for new users (name → brand colors → first project)"
    ]
  },

  "env_vars_required": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "STRIPE_SECRET_KEY",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_FREE_PRICE_ID",
    "STRIPE_PRO_PRICE_ID",
    "STRIPE_PREMIUM_PRICE_ID",
    "ARCHONX_API_URL",
    "ARCHONX_API_KEY",
    "NEXT_PUBLIC_APP_URL"
  ],
  "infisical_key_prefix": "SYNTHIA_",

  "test_requirements": [
    "test_pricing_page_renders_mxn: Verify $ MXN shown, USD secondary",
    "test_spanish_default_locale: Root / redirects to /es/",
    "test_auth_guard_dashboard: Unauthenticated /dashboard → redirect to /auth/login",
    "test_stripe_checkout_creates_session: Mock Stripe, verify checkout session fields",
    "test_ai_generation_rate_limit: Free plan at 10/10 → 429 response with upgrade CTA",
    "test_supabase_rls: User cannot access another user's projects (Row Level Security)",
    "test_mobile_viewport: All pages functional at 375px width"
  ],

  "builder_notes": [
    "MANDATORY: Load uncodixfy SKILL.md before writing ANY UI component. No generic AI UI.",
    "shadcn/ui uses CSS variables — override with SYNTHIA color palette in globals.css",
    "Stripe Checkout hosted page for MVP — no custom card forms (reduce PCI scope)",
    "Supabase RLS MUST be enabled on all tables — no bypasses",
    "AI generation endpoint rate-limits based on ai_usage table check before calling kernel",
    "DesignCanvas for MVP: structured JSON-to-HTML rendering (NOT a full canvas editor in Phase 2)",
    "Full canvas editor (Fabric.js or similar) is Phase 3 scope",
    "DO NOT use Vercel AI SDK for AI calls — proxy through ARCHON-X kernel API (consistent with system)"
  ]
}
